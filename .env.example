# ============================================================
# Sistema Zeus - Variáveis de Ambiente (Exemplo)
# ============================================================
# Copie este arquivo para `.env` e preencha com os valores reais.
# NUNCA commite o arquivo `.env` com credenciais de produção!
# ============================================================

# --- Banco de Dados PostgreSQL ---
# Dados de conexão individuais (usados por Drizzle ORM)
PG_HOST=localhost
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=sua_senha_aqui
PG_DB=nexushub_db

# String de conexão completa (formato padrão PostgreSQL)
DATABASE_URL=postgresql://postgres:sua_senha_aqui@localhost:5432/nexushub_db?schema=public

# --- Sessão e Segurança ---
# Segredo de assinatura HMAC para os tokens de sessão.
# Gere um valor forte com: openssl rand -base64 32
# OBRIGATÓRIO em produção.
AUTH_SECRET=mude_este_valor_para_um_segredo_forte_em_producao

# --- Funcionalidades Opcionais ---
# Documentação interativa Swagger UI em /docs
# true  → habilita /docs e /api/openapi (somente desenvolvimento)
# false → desativa completamente, retorna 404
DOCS_ENABLED=true

# --- Integração Google Gemini AI (Opcional) ---
# Obtenha sua API Key em: https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=

# --- Ambiente Next.js ---
# Definido automaticamente pelo Next.js (development | production | test)
# NODE_ENV=development
